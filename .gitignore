cat > .gitignore << 'EOF'
# Python
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.env

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Models - only keep latest
models/isolation_forest_v*.pkl
#Allow fraud_detector_latest.pkl

# Data - large files
*.csv
# Allow specific training data
!data/fraud_training_data.csv

# Logs
*.log

# Environment
.env
*.env

# Database
*.db
*.sqlite
EOF